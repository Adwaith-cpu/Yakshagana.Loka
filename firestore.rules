rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'adwaithbaburaj30@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      );
    }

    function isManager() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getUserData().role == 'manager' || getUserData().role == 'admin');
    }

    function incoming() {
      return request.resource.data;
    }

    // COLLECTION MATCHES
    match /users/{userId} {
      // Allow users to read, create, and update their own profile
      allow get, create, update: if isSignedIn() && request.auth.uid == userId;
      // Admins can manage all users
      allow list, update: if isAdmin();
    }

    match /artists/{artistId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /shows/{showId} {
      allow read: if true;
      allow create, update, delete: if isManager();
    }

    match /audio_clips/{clipId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
